name: Scrape Wantedly Jobs

on:
  schedule:
    - cron: '0 0 * * *'  # 毎日9時（日本時間）
  workflow_dispatch:     # 手動実行も可能

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: リポジトリ取得
        uses: actions/checkout@v3

      - name: Pythonセットアップ
        uses: actions/setup-python@v4
        with:
          python-version: '3.11'

      - name: ライブラリインストール
        run: |
          pip install requests beautifulsoup4 pandas

      - name: スクレイピング実行
        run: |
          python scraper.py

      - name: 変更をコミット
        run: |
          git config --global user.name "github-actions"
          git config --global user.email "actions@github.com"
          git add wantedly_jobs.csv
          git commit -m "update jobs" || echo "no changes"
          git push
